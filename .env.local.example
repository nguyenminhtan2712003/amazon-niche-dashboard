# =============================================================================
# Hai cách chạy dashboard — chọn 1:
# =============================================================================

# ----- CÁCH 1: STATIC MODE (đơn giản nhất, không cần backend) -----
# Để trống FASTAPI_URL. Next.js sẽ đọc thẳng dashboard_data.json từ project folder.
FASTAPI_URL=
FASTAPI_KEY=
SNAPSHOT_REVALIDATE=0

# ----- CÁCH 2: FASTAPI MODE (khi đã có server riêng) -----
# Uncomment 3 dòng dưới và bỏ comment 3 dòng trên:
# FASTAPI_URL=http://localhost:8000
# FASTAPI_KEY=your-api-key
# SNAPSHOT_REVALIDATE=300

# ----- (Optional) Override đường dẫn data file cho STATIC mode -----
# DATA_FILE_PATH=C:\path\to\dashboard_data.json
